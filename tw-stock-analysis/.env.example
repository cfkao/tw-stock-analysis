# =============================================
# 台股價值投資分析系統 — 環境變數設定
# 複製此檔案為 .env 並填入實際值
# =============================================

# === 資料庫 ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=tw_stock
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/tw_stock

# === FinMind API ===
# 註冊網址: https://finmindtrade.com/analysis/#/Sponsor/sponsor
FINMIND_API_TOKEN=your_finmind_token_here

# === Line Bot (Phase 5) ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# === 應用程式 ===
APP_ENV=development
SECRET_KEY=your_secret_key_here
BACKEND_CORS_ORIGINS=http://localhost:5173
